{
  "name": "header-helper",
  "displayName": "Header Helper",
  "description": "Turn // >[text] into editable ASCII box section headers",
  "version": "0.2.0",
  "publisher": "terminalsin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/terminalsin/vscode-header-helper.git"
  },
  "bugs": {
    "url": "https://github.com/terminalsin/vscode-header-helper/issues"
  },
  "homepage": "https://github.com/terminalsin/vscode-header-helper#readme",
  "keywords": [
    "header",
    "comment",
    "ascii",
    "section",
    "box",
    "markdown"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Header Helper",
      "properties": {
        "headerHelper.length": {
          "type": "number",
          "default": 70,
          "minimum": 20,
          "maximum": 120,
          "scope": "resource",
          "description": "Inner width of the ASCII box (characters between the vertical borders)."
        },
        "headerHelper.align": {
          "type": "string",
          "enum": [
            "center",
            "left",
            "right"
          ],
          "default": "center",
          "scope": "resource",
          "description": "Horizontal alignment of the title inside the box."
        },
        "headerHelper.innerWidth": {
          "type": "number",
          "default": 70,
          "minimum": 20,
          "maximum": 120,
          "scope": "resource",
          "markdownDeprecationMessage": "Use **headerHelper.length** instead.",
          "description": "Deprecated. Use headerHelper.length."
        },
        "headerHelper.uppercase": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Show header text in uppercase inside the ASCII box.",
          "markdownDescription": "When enabled, the title inside the box is uppercased (e.g. `Constants` → `CONSTANTS`). The `// >[text]` marker always keeps the casing you type."
        }
      }
    },
    "commands": [
      {
        "command": "header-helper.deleteLeft",
        "title": "Header Helper: Delete Left (content only)"
      },
      {
        "command": "header-helper.deleteRight",
        "title": "Header Helper: Delete Right (content only)"
      },
      {
        "command": "header-helper.deleteAllLeft",
        "title": "Header Helper: Delete to Content Start"
      },
      {
        "command": "header-helper.deleteAllRight",
        "title": "Header Helper: Delete to Content End"
      },
      {
        "command": "header-helper.deleteWordLeft",
        "title": "Header Helper: Delete Word Left (content only)"
      },
      {
        "command": "header-helper.deleteWordRight",
        "title": "Header Helper: Delete Word Right (content only)"
      },
      {
        "command": "header-helper.insertMarkerLine",
        "title": "Header Helper: New Marker Line"
      }
    ],
    "keybindings": [
      {
        "command": "header-helper.deleteLeft",
        "key": "backspace",
        "when": "editorTextFocus && headerHelper.focusInHeader"
      },
      {
        "command": "header-helper.deleteRight",
        "key": "delete",
        "when": "editorTextFocus && headerHelper.focusInHeader"
      },
      {
        "command": "header-helper.deleteAllLeft",
        "key": "ctrl+backspace",
        "mac": "cmd+backspace",
        "when": "editorTextFocus && headerHelper.focusInHeader"
      },
      {
        "command": "header-helper.deleteAllRight",
        "key": "ctrl+delete",
        "mac": "cmd+delete",
        "when": "editorTextFocus && headerHelper.focusInHeader"
      },
      {
        "command": "header-helper.deleteWordLeft",
        "key": "alt+backspace",
        "mac": "alt+backspace",
        "when": "editorTextFocus && headerHelper.focusInHeader"
      },
      {
        "command": "header-helper.deleteWordRight",
        "key": "alt+delete",
        "mac": "alt+delete",
        "when": "editorTextFocus && headerHelper.focusInHeader"
      },
      {
        "command": "header-helper.insertMarkerLine",
        "key": "enter",
        "when": "editorTextFocus && headerHelper.collapsedEdit"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:openvsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "ovsx": "^0.10.12",
    "typescript": "^5.3.3"
  }
}
